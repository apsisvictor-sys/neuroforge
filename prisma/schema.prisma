generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionTier {
  free
  premium
  professional
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  createdAt        DateTime         @default(now())
  lastActiveAt     DateTime         @default(now())
  subscriptionTier SubscriptionTier @default(free)
  stripeCustomerId String?          @unique
  profile          Profile?
  sessions         Session[]
  magicTokens      MagicToken[]
  enrollments      Enrollment[]
  dailyTasks       DailyTask[]
  streak           Streak?
  checkins         Checkin[]
  conversations    Conversation[]
}

model Profile {
  userId              String @id
  displayName         String
  timezone            String
  onboardingCompleted Boolean @default(false)
  onboardingAnswers   Json?
  userState           Json?
  user                User @relation(fields: [userId], references: [id])
}

model Session {
  token     String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model MagicToken {
  token     String   @id
  userId    String
  email     String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
}

model Enrollment {
  id         String   @id @default(uuid())
  userId     String
  protocolId String
  startDate  String
  active     Boolean  @default(true)
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, active])
}

model DailyTask {
  id                String    @id
  userId            String
  protocolId        String
  phaseId           String
  dayKey            String
  taskDefinitionId  String
  title             String
  instructions      String
  category          String
  estimatedMinutes  Int
  order             Int
  required          Boolean   @default(true)
  completed         Boolean   @default(false)
  completedAt       DateTime?

  user              User      @relation(fields: [userId], references: [id])

  @@index([userId, dayKey])
}

model Streak {
  userId              String  @id
  currentStreak       Int
  lastQualifiedDayKey String?
  user                User    @relation(fields: [userId], references: [id])
}

model Checkin {
  id        String   @id @default(uuid())
  userId    String
  dayKey    String
  focus     Int
  calm      Int
  energy    Int
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, dayKey])
  @@index([userId, dayKey(sort: Desc)])
}

model Conversation {
  id         String    @id @default(uuid())
  userId     String
  protocolId String
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
  messages   Message[]

  @@unique([userId, protocolId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())
  inputTokens    Int?
  outputTokens   Int?
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
}

enum MessageRole {
  user
  assistant
}
